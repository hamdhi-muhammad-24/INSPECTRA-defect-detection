# Copy this file to .env and fill in your real values.
# Never commit .env to Git.

# Google Gemini API key — get one free at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# Qdrant vector database (matches docker-compose.yml defaults)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=inspectra_rag_documents

# Paths — relative to the backend/ working directory
DATASET_PATH=../data/mvtec_ad
RAG_DOCS_PATH=../data/rag_documents
MODEL_DIR=../models/trained
REPORTS_DIR=../reports/generated_reports

# SQLite — path is relative to the backend/ working directory
DATABASE_URL=sqlite:///./inspectra.db

# App
APP_ENV=development

# Comma-separated allowed CORS origins
CORS_ORIGINS=http://localhost:5173
